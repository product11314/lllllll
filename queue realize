package com.example;
class QUEUE{
    public int[] queue;
    public int l,r;
    
    public void generator(int n ){
        queue = new int[n];
        l = 0;
        r = 0;
    }

    public void push(int val){
        if(isfull()){
            resize();
        }else{
            queue[r++] = val;
        }
    }

    public int extract(){
        return queue[l++];
    }

    public boolean isempty(){
        return l == r;
    }

    public boolean isfull(){
        return r == queue.length;
    }

    private void resize(){
        int newrange = queue.length + (queue.length>>1);
        int[] newqueue = new int[newrange];
        System.arraycopy(queue, 0, newrange, 0, queue.length);
        queue = newqueue;
    }

    class Mycircularqueue{
        public int[] queue;
		public int l,r;
        public int size,limit;
        public void Mycircularqueue(int k){
            queue = new int[k];
			l = r = size = 0;
			limit = k;
        }

       public boolean push(int val){
            if(isfull()){
                return false;
            }else{
                queue[r] = val;
                r = r == limit-1 ? 0 : r+1;
                size ++;
                return true;
            }
        }
        
        public boolean poll(){
            if(isempty()){
                return false;
            }else{
                l = l == limit-1 ? 0 : l+1;
                size --;
                return true;
            }
        }

        public boolean isfull(){
            return size == limit;
        }

        public boolean isempty(){
            return size == 0;
        }
    }
}
